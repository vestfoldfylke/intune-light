@using IntuneLight.Infrastructure
@implements IDisposable

<MudNavMenu Class="custom-nav-menu">

    <MudStack Row AlignItems="AlignItems.Center" Justify="Justify.FlexStart" Class="ml-5 my-10">
        <MudBadge Dot Color="Color.Success" Overlap="true">
            <MudAvatar Color="Color.Dark" Size="Size.Medium">
                <MudIcon Icon="@Icons.Material.Filled.SupportAgent" />
            </MudAvatar>
        </MudBadge>
        <MudText Typo="Typo.subtitle1">Nils Solberg</MudText>
    </MudStack>

    <MudText Class="version ml-5 mb-5" Typo="Typo.subtitle1">
        Versjon - @version
    </MudText>

</MudNavMenu>


@code
{
	protected override void OnInitialized()
	{
		_state.StateChanged += StateHasChanged;
	}

	private string version = typeof(Program)?.Assembly.GetName()?.Version?.ToString() ?? "ukjent";

    public void Dispose ()=> _state.StateChanged -= StateHasChanged;
}