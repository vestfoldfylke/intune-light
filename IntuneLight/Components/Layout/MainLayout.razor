@using IntuneLight.Components.Custom
@using IntuneLight.Infrastructure
@using IntuneLight.Models.Options
@using Microsoft.Extensions.Options
@inherits LayoutComponentBase
@implements IDisposable
@inject IOptions<PureserviceOptions> _psOptions
@inject IJSRuntime _js
@inject IHttpContextAccessor HttpContextAccessor

<MudThemeProvider Theme="@_companyTheme" IsDarkMode="_state.IsDarkMode" />
<MudPopoverProvider />
<MudDialogProvider />
<MudSnackbarProvider />

<MudLayout>

    <MudAppBar Elevation="1">

        <MudImage Src="/img/intune-light.png" Height="20"/>

        <MudText Typo="Typo.h6" Class="ml-3" Color="Color.Inherit">
            <MudStack Row="true" Spacing="1">
                <b>Intune</b>
				<p style="font-weight:300">Light</p>
            </MudStack>
        </MudText>

        <MudSpacer />

        <MudIconButton Icon="@(DarkLightModeButtonIcon)" Color="Color.Inherit" OnClick="@DarkModeToggle" />

        <MudMenu Icon="@Icons.Material.Filled.MoreVert" 
                 Color="Color.Inherit" 
                 AnchorOrigin="Origin.BottomLeft" 
                 TransformOrigin="Origin.TopCenter">
            <MudMenuItem Icon="@Icons.Material.Outlined.ExitToApp">Logg ut</MudMenuItem>
        </MudMenu>

    </MudAppBar>

    <MudDrawer id="nav-drawer" @bind-Open="_drawerOpen" ClipMode="DrawerClipMode.Always" Elevation="2">
        <NavMenu/>
    </MudDrawer>

    <MudMainContent>
        @Body
    </MudMainContent>

</MudLayout>

@* Custom error bar component to show fatal errors *@
<FatalErrorBar />


@code 
{
    #region Parameters

    private bool _drawerOpen = true;

    #endregion

	#region Initialization

    protected override void OnInitialized()
    {
		// Subscribe to state changes
        _state.StateChanged += StateHasChanged;

		// Fetch darkmode preference from cookies (server-side rendering)
        var cookie = HttpContextAccessor.HttpContext?.Request.Cookies["darkMode"];
        _state.IsDarkMode = cookie == "true";

		// Set pureservice ticket url from options
		_state.PureserviceTicketAddress = _psOptions.Value.TicketAddress;
        
        base.OnInitialized();
    }

    #endregion

    #region Company theme

    MudTheme _companyTheme = new()
    {
        LayoutProperties = new LayoutProperties
        {
            DefaultBorderRadius = "4px" // 25px - affects all components like cards, fields etc..
        },

        // LIGHT THEME
        PaletteLight = new PaletteLight
        {

            // Accent colors (100%)
            Primary = "#009BC2",                // Himmel 100 %
            Secondary = "#14828C",              // Fjord 100 %
            Tertiary = "#5A2E61",               // Plomme 100 %

            // UI/Surface
            AppbarBackground = "#005260",       // Vann 100 %
            AppbarText = Colors.Shades.White,

            Background = "#F5F5F5",             // Lys grå bakgrunn
            Surface = Colors.Shades.White,
            DrawerBackground = "#E3E6E8",
            DrawerText = Colors.Gray.Darken3,
            DrawerIcon = Colors.Gray.Darken2,

            TextPrimary = Colors.Gray.Darken4,
            TextSecondary = Colors.Gray.Darken1,

            // Status colors (100 %)
            Success = "#1F9562",                // Gress 100 %
            Warning = "#BC7726",                // Siv 100 %
            Error = "#B7173D",                  // Nype 100 %
            Info = "#009BC2",                   // Himmel 100%

            Divider = "#DDDDDD"
        },

        // DARK THEME
        PaletteDark = new PaletteDark
        {
            // DARK – accent colors
            Primary = "#9ADCEB",               // Himmel ~ 65 %  (lys, tydelig, action/links)
            Secondary = "#7FD3E3",             // Himmel/Fjord ~ 55 % (sekundær, roligere)
            Tertiary = "#B59BC0",              // Plomme ~ 55 %

            // Status colors
            Success = "#3FA884",                // Gress ~ 55 %
            Warning = "#B8833A",                // Siv ~ 55 %
            Error = "#B64B66",                  // Nype ~ 55 %
            Info = "#3FA1B8",                   // Himmel ~ 55 %

            // Appbar / navigation
            AppbarBackground = "#172126",       // Vann (Dark base) ~ 90 %
            AppbarText = "#D7DEE3",             // Stein lys ~ 85 %

            // Surfaces (light-dark)
            Background = "#1E262B",             // Dark base (not near-black)
            Surface = "#2A343B",                // Card/panel (clearly lighter)
            DrawerBackground = "#182025",       // Slightly deeper than bg

            // Text (soft contrast, less glare)
            TextPrimary = "#D7DEE3",            // Stein lys ~ 85 %
            TextSecondary = "#AEBAC2",          // Stein lys ~ 70 %

            // Icons / divider
            DrawerText = "#C9D2D8",             // ~ 80 %
            DrawerIcon = "#9EABB3",             // ~ 65 %
            Divider = "#3A4851"                 // subtle but visible
        },

        // TYPOGRAPHY
        Typography = new Typography
        {
            // Global default: Nunito Sans for body text
            Default = new DefaultTypography() { FontFamily = new[] { "Nunito Sans", "Calibri", "Segoe UI", "Arial", "sans-serif" }},

            // Nunito
            H1 = new H1Typography { FontFamily = new[] { "Nunito", "Calibri", "Segoe UI", "Arial", "sans-serif" }},
            H2 = new H2Typography { FontFamily = new[] { "Nunito", "Calibri", "Segoe UI", "Arial", "sans-serif" }},
            H3 = new H3Typography { FontFamily = new[] { "Nunito", "Calibri", "Segoe UI", "Arial", "sans-serif" }},
            H4 = new H4Typography { FontFamily = new[] { "Nunito", "Calibri", "Segoe UI", "Arial", "sans-serif" }},

            // Nunito Sans
            H5 = new H5Typography { FontFamily = new[] { "Nunito Sans", "Calibri", "Segoe UI", "Arial", "sans-serif" } },
            H6 = new H6Typography { FontFamily = new[] { "Nunito Sans", "Calibri", "Segoe UI", "Arial", "sans-serif" } },
            Subtitle1 = new Subtitle1Typography { FontFamily = new[] { "Nunito Sans", "Calibri", "Segoe UI", "Arial", "sans-serif" }},
            Subtitle2 = new Subtitle2Typography { FontFamily = new[] { "Nunito Sans", "Calibri", "Segoe UI", "Arial", "sans-serif" }},
            Overline = new OverlineTypography   { FontFamily = new[] { "Nunito Sans", "Calibri", "Segoe UI", "Arial", "sans-serif" }},
            Body1 = new Body1Typography { FontFamily = new[] { "Nunito Sans", "Calibri", "Segoe UI", "Arial", "sans-serif" }},
            Body2 = new Body2Typography { FontFamily = new[] { "Nunito Sans", "Calibri", "Segoe UI", "Arial", "sans-serif" }},
            Button = new ButtonTypography { FontFamily = new[] { "Nunito Sans", "Calibri", "Segoe UI", "Arial", "sans-serif" }},
            Caption = new CaptionTypography { FontFamily = new[] { "Nunito Sans", "Calibri", "Segoe UI", "Arial", "sans-serif" }}
        }
    };

    #endregion

    #region Events

    private void DrawerToggle() => _drawerOpen = !_drawerOpen;
    
    // Toggles dark mode and persists preference in cookie.
    private async Task DarkModeToggle()
    {
        _state.IsDarkMode = !_state.IsDarkMode;
        await _js.InvokeVoidAsync( "setDarkMode", _state.IsDarkMode );
    }

    public string DarkLightModeButtonIcon => _state.IsDarkMode switch
    {
        true => Icons.Material.Rounded.AutoMode,
        false => Icons.Material.Outlined.DarkMode,
    };

    #endregion

	#region Dispose

	// Cleanup state change event subscription
    public void Dispose()
    {
		_state.StateChanged -= StateHasChanged;
	}

    #endregion

}


