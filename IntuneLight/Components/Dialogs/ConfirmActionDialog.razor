@using MudBlazor

<MudDialog DefaultFocus="DefaultFocus.None" ActionsClass="ma-5" TitleClass="my-2">
    <DialogContent>
        <MudStack Spacing="3" Class="mt-5">
            @if (!string.IsNullOrWhiteSpace(Message))
            {
                <MudText Typo="Typo.body1" Class="preserve-linebreaks">
                    @((MarkupString)Message)
                </MudText>
            }

            @if (IsIrreversible)
            {
                <MudStack Row Class="mt-3">
                    <MudIcon Icon="@Icons.Material.Outlined.Warning" Color="Color.Warning"/>
                    <MudText Typo="Typo.body2" Style="font-size:16px" Class="mt-1">
                        Obs! Denne handlingen kan ikke angres.
                    </MudText>
                </MudStack>
            }
        </MudStack>
    </DialogContent>

    <DialogActions>
        <MudButton Variant="Variant.Text" OnClick="Cancel">@CancelText</MudButton>
        <MudButton Variant="Variant.Filled"
                   Color="Color.Error"
                   Style="min-width:100px"
                   OnClick="Confirm">
            @ConfirmText
        </MudButton>
    </DialogActions>
</MudDialog>

@code 
{
    [CascadingParameter] private IMudDialogInstance _dialog { get; set; } = default!;

    [Parameter] public string Title { get; set; } = "Bekreft handlingen";
    [Parameter] public string? Message { get; set; }
    [Parameter] public bool IsIrreversible { get; set; } = true;
    [Parameter] public string ConfirmText { get; set; } = "Fortsett";
    [Parameter] public string CancelText { get; set; } = "Avbryt";

    // Closes the dialog returning a successful confirmation result.
    private void Confirm ()=> _dialog.Close(DialogResult.Ok(true));

    // Cancels the dialog without performing the action.
    private void Cancel ()=> _dialog.Cancel(); // Return cancelled
}
