@using IntuneLight.Models.Offboarding

<MudDialog>
    <TitleContent>
        <MudText Typo="Typo.h6">
            <MudIcon Icon="@Icons.Material.Outlined.Logout" Class="mr-2" Color="Color.Error" />
            Start offboarding
        </MudText>
    </TitleContent>
    <DialogContent>
        <MudStack Spacing="3">
            <MudText Typo="Typo.body1">
                Dette er <b>irreversibelt</b> og vil påvirke enheten i flere systemer.
            </MudText>
            <MudAlert Severity="Severity.Warning" Dense="true">
                Sørg for at enheten er online og aktiv i Intune før du fortsetter.
            </MudAlert>
            <MudRadioGroup @bind-Value="_selectedType">
                <MudStack Spacing="3">
                    <MudRadio Value="OffboardingType.RemoveAutopilot" Color="Color.Default">
                        <MudStack Spacing="0">
                            <MudText Typo="Typo.body1"><b>Fjern fra Autopilot</b></MudText>
                            <MudText Typo="Typo.body2">Fjerner fra Autopilot, oppdaterer Defender og Pureservice. Bruker resetter selv via firmaportal.</MudText>
                        </MudStack>
                    </MudRadio>
                    <MudRadio Value="OffboardingType.WithWipe" Color="Color.Error">
                        <MudStack Spacing="0">
                            <MudText Typo="Typo.body1"><b>Wipe enhet</b></MudText>
                            <MudText Typo="Typo.body2">Sender wipe-kommando og fjerner enheten fra Intune og Entra. Enheten nullstilles av IT.</MudText>
                        </MudStack>
                    </MudRadio>
                </MudStack>
            </MudRadioGroup>
        </MudStack>
    </DialogContent>
    <DialogActions>
        <MudButton OnClick="@(() => MudDialog.Close(DialogResult.Cancel()))"
                   Variant="Variant.Text">
            Avbryt
        </MudButton>
        <MudButton OnClick="@(() => MudDialog.Close(DialogResult.Ok(_selectedType)))"
                   Color="Color.Error"
                   Variant="Variant.Filled"
                   Disabled="@(_selectedType == OffboardingType.None)">
            Start offboarding
        </MudButton>
    </DialogActions>
</MudDialog>

@code 
{
    [CascadingParameter] IMudDialogInstance MudDialog { get; set; } = default!;
    private OffboardingType _selectedType = OffboardingType.None;
}