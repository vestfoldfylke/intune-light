@code
{
    #region Parameters

    // Time the ferch operation
    private double _currentSearchSeconds;          
    private double? _lastSearchSeconds;           
    private System.Timers.Timer? _searchTimer;

    // Select pureservice icon based om theme
    private string pureserviceIcon => _state.IsDarkMode ? "/img/pureservice_light.png" : "/img/pureservice_dark.png";

    // Style for search filed
    private string containerStyle => _state.ManagedDevice == null ? "margin-top:100px;max-width:1800px;" : "margin-top:50px;max-width:1800px;";

    // Refresh target (indeterminate) loading spinner
    private RefreshTarget? _loadingTarget;

    // Returns true if the specified target is currently loading.
    private bool IsLoading(RefreshTarget target) => _loadingTarget == target;

    #endregion

    #region Initializations

    protected override void OnInitialized()
    {
        _state.StateChanged += StateHasChanged;
    }

    #endregion

    #region Search

    // Handles the Enter key on the search field and triggers a device lookup.
    private async Task HandleSearchKeyDown(KeyboardEventArgs args)
    {
        if (args.Key != "Enter")
            return;

        if (_state.IsFetching || !_state.IsSearchSerialValid)
            return;

        await SearchAsync();
    }

    // Looks up a device by serial number and enriches it with data from several services.
    private async Task SearchAsync()
    {
        if (!_state.IsSearchSerialValid || _state.IsFetching)
        {
            _snackbar.Add("Skriv inn ett gylding serienummer før du søker.", Severity.Warning);
            return;
        }

        _state.IsFetching = true;
        _state.HasSearched = false;
        _state.ClearResults(keepSearchSerial: true);
        StartSearchTimer();

        // Perform the search and data enrichment.
        var results = new DeviceLookupResults();

        await _uiErrorHandler.RunSafeAsync(
            async () =>
            {
                // Resolve Intune managed device by serial number.
                results.ManagedDevice = await _intuneService.GetDeviceBySerialAsync(_state.SearchSerial);
                if (results.ManagedDevice is null) 
                    return;

                // Fetch Autopilot device info.
                results.AutopilotDevice = await _intuneService.GetAutopilotDeviceBySerialAsync(results.ManagedDevice.SerialNumber);

                // Resolve Defender device from AAD device id.
                results.DefenderDevice = await _defenderService.GetDeviceByAadDeviceIdAsync(results.ManagedDevice.AzureADDeviceId);

                // Fetch device isolation status from defender
                if (results.DefenderDevice is not null)
                    results.IsIsolated = await _defenderService.GetIsolationStatusByMachineId(results.DefenderDevice.Id);

                // Fetch BitLocker recovery key.
                results.BitlockerRecoveryKey = await _intuneService.GetBitlockerRecoveryKeyByAzureAdDeviceIdAsync(results.ManagedDevice.AzureADDeviceId);

                // Fetch LAPS password.
                results.DeviceCredential = await _intuneService.GetLapsPasswordByAzureDeviceId(results.ManagedDevice.AzureADDeviceId);

                // Fetch pureservice asset by serial number, then by id for full details
                results.PureserviceAssetBySn = await _pureserviceService.GetAssetBySerialAsync(results.ManagedDevice.SerialNumber);

                // Fetch pureservice asset relationships by asset id
                if (results.PureserviceAssetBySn is not null)
                    results.PureserviceRelationships = await _pureserviceService.GetRelationshipsByAssetIdAsync(results.PureserviceAssetBySn.Id.ToString());

                // Try to get the first ticket related to the asset
                if(results.PureserviceRelationships is not null)
                {
                    if (results.PureserviceRelationships.Relationships != null)
                    {
                        // Finn første ticket-relasjon
                        var ticketRel = results.PureserviceRelationships.Relationships.FirstOrDefault(r => r.ToTicketId.HasValue);
                        var ticket = results.PureserviceRelationships.Linked.Tickets.FirstOrDefault(t => t.Id == ticketRel?.ToTicketId);
                        var user = results.PureserviceRelationships.Linked.Users.FirstOrDefault(); // eller match via links

                        if (ticket != null)
                            results.PureserviceTicket = ticket;
                    }
                }

                // Fetch Entra device by device id
                results.EntraDevice = await _entraDirectoryService.GetDeviceByAzureAdDeviceIdAsync(results.ManagedDevice.AzureADDeviceId);

                // Fetch Pureservice user by email (UPN).
                results.PureserviceUser = await _pureserviceService.GetUserByEmailAsync(results.ManagedDevice.UserPrincipalName);

                // Resolve Entra user by UPN.
                results.EntraUser = await _entraDirectoryService.GetUserByUpnAsync(results.ManagedDevice.UserPrincipalName);

                // Fetch entra user photo
                if (results.EntraUser is not null)
                    results.EntraUserPhoto = await _entraDirectoryService.GetUserPhotoAsync(results.EntraUser.Id);

                // Try to count UserDevice
                if (results.EntraUser is not null)
                    results.EntraDeviceCount = await _entraDirectoryService.GetRegisteredDevicesForUser(results.EntraUser.Id);

                // Count and attach raw json from entra device query
                if (results.EntraDeviceCount is not null)
                    results.UserDeviceCount = results.EntraDeviceCount.Count;
            },
            after: () =>
            {
                // Only persist results when we actually found a device
                if (results.ManagedDevice is not null)
                    _state.SetResults(results);

                _state.IsFetching = false;
                _state.HasSearched = true;
                StopSearchTimer();

            });
    }

    // Clear search results and reset state.
    private void ClearSearchResult()
    {
        StopSearchTimer();

        _currentSearchSeconds = 0;
        _lastSearchSeconds = null;

        _state.HasSearched = false;
        _state.ClearResults(keepSearchSerial: false);
    }

    #endregion

    #region Dialogs

    // Opens a dialog that displays raw JSON data in a formatted viewer.
    private async Task ShowJsonViewer(string json)
    {
        if (string.IsNullOrWhiteSpace(json))
            return;

        var parameters = new DialogParameters
        {
            ["Json"] = json
        };

        var options = new DialogOptions
        {
            MaxWidth = MaxWidth.Large,
            FullWidth = true,
            CloseButton = true,
            BackdropClick = false
        };

        await _dialogService.ShowAsync<JsonViewerDialog>("Rådata", parameters, options);
    }

    #endregion

    #region Timer

    // Starts the stopwatch-like timer that updates the elapsed seconds while the API search is running.
    private void StartSearchTimer()
    {
        StopSearchTimer();                         // ensure no old timer
        _currentSearchSeconds = 0;                 // reset live counter

        _searchTimer = new System.Timers.Timer(100); // 0.1 s interval
        _searchTimer.Elapsed += async (_, _) =>
        {
            _currentSearchSeconds += 0.1;          // update live counter
            await InvokeAsync(StateHasChanged);    // refresh UI
        };
        _searchTimer.AutoReset = true;
        _searchTimer.Start();
    }

    // Stops and disposes the search timer when the API call completes.
    private void StopSearchTimer()
    {
        if (_searchTimer is null)
            return;

        _searchTimer.Stop();
        _searchTimer.Dispose();
        _searchTimer = null;

        // Store last search duration so it stays visible
        _lastSearchSeconds = _currentSearchSeconds;
    }

    #endregion

    #region Helpers

    // Maps Intune compliance state to a UI badge (icon, color, and label).
    private static (string icon, Color color, string label) MapComplianceBadge(string? state)
    {
        // Normalize input from Graph/Intune (string values like "compliant", "noncompliant", etc.)
        var s = (state ?? string.Empty).Trim().ToLowerInvariant();

        return s switch
        {
            "compliant" => (Icons.Material.Outlined.CheckCircle, Color.Success, "Kompatibel"),
            "noncompliant" => (Icons.Material.Outlined.Block, Color.Error, "Ikke kompatibel"),
            "ingraceperiod" => (Icons.Material.Outlined.Schedule, Color.Warning, "I overgangsperiode"),
            "conflict" => (Icons.Material.Outlined.Report, Color.Warning, "Regelkonflikt"),
            "error" => (Icons.Material.Outlined.ErrorOutline, Color.Error, "Feil"),
            "configmanager" => (Icons.Material.Outlined.Settings, Color.Info, "ConfigMgr"),
            _ => (Icons.Material.Outlined.HelpOutline, Color.Default, "Ukjent")
        }; ;
    }

    private (string icon, Color color) GetEntraUserStatusBadge(EntraUser? user)
    {
        if (user is null)
            return (Icons.Material.Outlined.HelpOutline, Color.Default);

        return user.AccountEnabled
            ? (Icons.Material.Outlined.CheckCircle, Color.Success)
            : (Icons.Material.Outlined.Block, Color.Error);
    }

    private string? UserPhotoDataUrl => _state.EntraUserPhoto is { Length: > 0 }
                    ? $"data:image/jpeg;base64,{Convert.ToBase64String(_state.EntraUserPhoto)}"
                    : null;

    #endregion

    #region Dispose

    // Ensures the timer is cleaned up if the component is disposed.
    public void Dispose() 
    {
        _state.StateChanged -= StateHasChanged;
        StopSearchTimer();
    }

    #endregion
}