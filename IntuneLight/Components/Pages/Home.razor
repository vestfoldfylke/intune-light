@page "/"
@using IntuneLight.Components.Custom
@using IntuneLight.Components.Dialogs
@using IntuneLight.Helpers
@using IntuneLight.Models.Defender
@using IntuneLight.Models.Entra
@using IntuneLight.Models.Intune
@using IntuneLight.Models.Pureservice
@using IntuneLight.Models.State
@implements IDisposable

<PageTitle>Hjem</PageTitle>

@* Main container *@
<MudContainer Style="@containerStyle" Class="mb-16">

    @* Intro and searchbar *@
    <MudContainer MaxWidth="MaxWidth.Large" Class="my-16">

        @* Intro *@
        @if (_state.ManagedDevice == null)
        {
            <MudStack Justify="Justify.Center" Row Class="my-10" Style="width:100% !important">
                <MudImage Src="/img/intune-light.png" Height="80" Alt="Intune light logo"/>
                <MudText Typo="Typo.h4" Align="Align.Center">
                    <b>Intune</b> <p style="font-weight:300">Light</p>
                </MudText>
            </MudStack>

            <MudStack Justify="Justify.Center">
                <MudText Typo="Typo.subtitle1" Align="Align.Center" Style="font-size:19px;font-weight:300">
                    Intune light er et forenklet verktøy for servicedesk som gjør det enkelt å håndtere enheter.
                    Løsningen gir tilgang til nødvendige device‑management funksjoner – og kun det som trengs for
                    daglige oppgaver som sletting, nullstilling og generell administrasjon.
                </MudText>
            </MudStack>
        }

        @* Search bar *@
        <MudGrid Justify="Justify.Center" Class="mt-10">

            <MudItem xs="12" lg="12" md="12">
                @if (_lastSearchSeconds.HasValue || _state.IsFetching)
                {
                    var secondsText = (_state.IsFetching ? _currentSearchSeconds : _lastSearchSeconds!.Value).ToString("0.0");

                    <div style="display:flex; justify-content:flex-end; width:100%;">
                        <MudStack Row="true" AlignItems="AlignItems.Center" Spacing="1" Class="mb-2 mr-2">
                            <MudIcon Icon="@Icons.Material.Outlined.Timer" />
                            <MudText Typo="Typo.caption">@secondsText s</MudText>
                        </MudStack>
                    </div>
                }
                else
                {
                    @* Dummy, replacement *@
                    <div style="height:32px"/>
                }

                <MudTextField @bind-Value="_state.SearchSerial"
                              Placeholder="Serienummer (f.eks. PV76KDF0)"
                              Adornment="Adornment.End"
                              AdornmentIcon="@Icons.Material.Filled.Search"
                              OnAdornmentClick="SearchAsync"
                              AdornmentColor="Color.Secondary"
                              Immediate="true"
                              Disabled="_state.IsFetching"
                              OnKeyDown="HandleSearchKeyDown"
                              Clearable="true"
                              OnClearButtonClick="ClearSearchResult"
                              Variant="Variant.Outlined"
                              MaxLength="40"
                              MaxLines="1"
                              ErrorText="_state.SearchSerialError" 
                              Error="@(!_state.IsSearchSerialValid)" />
            </MudItem>

            <MudItem xs="12" lg="12" md="12" Class="pt-0 mt-0">
                @if (_state.IsFetching)
                {
                    <div class="mx-8">
                        <MudProgressLinear Indeterminate="true" Color="Color.Info" Class="custom-progressbar" />
                    </div>
                }
            </MudItem>

        </MudGrid>

    </MudContainer>

    @* No device found *@
    @if (_state.HasSearched && _state.ManagedDevice is null && !_state.IsFetching)
    {
        <MudContainer MaxWidth="MaxWidth.Large">
            <MudAlert Severity="Severity.Warning">
                Ingen enhet ble funnet for serienummer <b>@_state.SearchSerial</b>.
            </MudAlert>
        </MudContainer>
    }

    @if (_state.ManagedDevice is not null)
    {
        @* Device compliance *@
        var badge = MapComplianceBadge(_state.ManagedDevice.ComplianceState);

        @* User compliance *@
        var userBadge = GetEntraUserStatusBadge(_state.EntraUser);

        @* Device overview *@
        <MudGrid Justify="Justify.Center" Spacing="3" Class="mt-10">

            @* Left card *@
            <MudItem xs="12" md="6" xl="6">
                <MudPaper Elevation="3" Class="px-5 py-7 overview-card">

                    <MudStack Row Class="my-2 overview-card-header" AlignItems="AlignItems.Center" Spacing="2">
                        <MudBadge Icon="@badge.icon"
                                  Color="@badge.color"
                                  Overlap="true">
                            <MudImage Src="img/laptop1.png" Height="30" />
                        </MudBadge>
                        <MudText Typo="Typo.h6" Class="ml-3">
                            @UiFormat.TextOrFallback(_state.ManagedDevice.DeviceName)
                        </MudText>
                    </MudStack>

                    <MudStack Row=true Justify="Justify.FlexStart" Spacing="16" Class="mt-5">

                        <MudStack Justify="Justify.FlexStart" AlignItems="AlignItems.Start" Spacing="5">
                            <div>
                                <MudText Typo="Typo.body2" Class="mb-1"><b>Serienummer:</b></MudText>
                                <MudText Typo="Typo.body2">
                                    @UiFormat.TextOrFallback(_state.ManagedDevice.SerialNumber)
                                </MudText>
                            </div>
                            <div>
                                <MudText Typo="Typo.body2" Class="mb-1"><b>WiFi MAC-adresse:</b></MudText>
                                <MudText Typo="Typo.body2">
                                    @UiFormat.TextOrFallback(_state.ManagedDevice.WiFiMacAddress)
                                </MudText>
                            </div>
                        </MudStack>

                        <MudStack Justify="Justify.FlexEnd" AlignItems="AlignItems.Start" Spacing="5">
                            <div>
                                <MudText Typo="Typo.body2" Class="mb-1"><b>Modell:</b></MudText>
                                <MudText Typo="Typo.body2">
                                    @UiFormat.TextOrFallback(_state.AutopilotDevice?.SystemFamily)
                                </MudText>
                            </div>
                            <div>
                                <MudText Typo="Typo.body2" Class="mb-1"><b>Produsent:</b></MudText>
                                <MudText Typo="Typo.body2">
                                    @UiFormat.TextOrFallback(_state.ManagedDevice.Manufacturer)
                                </MudText>
                            </div>
                        </MudStack>

                        <MudStack Justify="Justify.FlexEnd" AlignItems="AlignItems.Start" Spacing="5">
                            <div>
                                <MudText Typo="Typo.body2" Class="mb-1"><b>Autopilot tag:</b></MudText>
                                <MudText Typo="Typo.body2">
                                    @UiFormat.TextWithoutPrefixOrFallback(_state.AutopilotDevice?.GroupTag, "windows-ap-")
                                </MudText>
                            </div>
                            <div>
                                <MudText Typo="Typo.body2" Class="mb-1"><b>Autopilot status:</b></MudText>
                                <MudText Typo="Typo.body2">
                                    @UiFormat.TextOrFallback(_state.AutopilotDevice?.EnrollmentState)
                                </MudText>
                            </div>
                        </MudStack>

                    </MudStack>

                </MudPaper>
            </MudItem>

            @* Right card *@
            <MudItem xs="12" md="6" xl="6">
                <MudPaper Elevation="3" Class="px-5 py-7 overview-card">

                    <MudStack Row Class="my-2 overview-card-header" AlignItems="AlignItems.Center" Spacing="2">
                        <MudBadge Icon="@userBadge.icon"
                                  Color="@userBadge.color"
                                  Overlap="true">

                            <MudTooltip Placement="Placement.Right"
                                        Delay="300"
                                        Disabled="@(_state.EntraUserPhoto is null)">
                                <TooltipContent>
                                    <MudAvatar Size="Size.Large" Style="height:120px;width:120px">
                                        <MudImage Src="@UserPhotoDataUrl" ObjectFit="ObjectFit.Cover" />
                                    </MudAvatar>
                                </TooltipContent>
                                <ChildContent>
                                    <MudAvatar Size="Size.Medium"
                                               Style="height:40px;width:40px"
                                               Color="Color.Secondary">
                                        @if (_state.EntraUserPhoto is { Length: > 0 })
                                        {
                                            <MudImage Src="@UserPhotoDataUrl"
                                                      ObjectFit="ObjectFit.Cover" />
                                        }
                                        else
                                        {
                                            <MudIcon Icon="@Icons.Material.Filled.Person"
                                                     Style="font-size:26px" />
                                        }
                                    </MudAvatar>
                                </ChildContent>
                            </MudTooltip>
                        </MudBadge>
                        <MudText Typo="Typo.h6" Class="ml-3">
                            @UiFormat.TextOrFallback(_state.EntraUser?.DisplayName)
                        </MudText>
                    </MudStack>

                    <MudStack Row=true Justify="Justify.FlexStart" Spacing="16" Class="mt-5">

                        <MudStack Justify="Justify.FlexStart" AlignItems="AlignItems.Start" Spacing="5">
                            <div>
                                <MudText Typo="Typo.body2" Class="mb-1"><b>Tittel:</b></MudText>
                                <MudText Typo="Typo.body2">
                                    @UiFormat.TextOrFallback(_state.EntraUser?.JobTitle)
                                </MudText>
                            </div>
                            <div>
                                <MudText Typo="Typo.body2" Class="mb-1"><b>Konto:</b></MudText>
                                <MudText Typo="Typo.body2">
                                    @UiFormat.TextOrFallback(_state.EntraUser?.UserPrincipalName)       
                                </MudText>
                            </div>
                        </MudStack>

                        <MudStack Justify="Justify.FlexStart" AlignItems="AlignItems.Start" Spacing="5">
                            <div>
                                <MudText Typo="Typo.body2" Class="mb-1"><b>Mobil:</b></MudText>
                                <MudText Typo="Typo.body2">
                                    @UiFormat.TextOrFallback(_state.EntraUser?.MobilePhone)
                                 </MudText>
                            </div>
                            <div>
                                <MudText Typo="Typo.body2" Class="mb-1"><b>Lokasjon:</b></MudText>
                                <MudText Typo="Typo.body2">
                                    @UiFormat.TextOrFallback(_state.EntraUser?.OfficeLocation)      
                                </MudText>
                            </div>
                        </MudStack>

                        <MudStack Justify="Justify.FlexStart" AlignItems="AlignItems.Start" Spacing="5">
                            <div>
                                <MudText Typo="Typo.body2" Class="mb-1"><b>Avdeling:</b></MudText>
                                <MudText Typo="Typo.body2">
                                    @UiFormat.TextOrFallback(_state.EntraUser?.Department)
                                </MudText>
                            </div>
                            @if(!string.IsNullOrEmpty(_state.EntraUser?.Manager))
                            {
                                <div>
                                    <MudText Typo="Typo.body2" Class="mb-1"><b>Leder:</b></MudText>
                                    <MudText Typo="Typo.body2">
                                        @UiFormat.TextOrFallback(_state.EntraUser?.Manager)
                                     </MudText>
                                </div>
                            }
                        </MudStack>

                    </MudStack>

                </MudPaper>
            </MudItem>

        </MudGrid>

        @* System cards *@
        <MudGrid Spacing="5" Class="mt-2">

            @* ENTRA | User *@
            <MudItem xs="12" md="6" lg="4">
                <MudCard Class="device-card" Elevation="3">

                    <MudCardContent Class="device-card-content">

                        <MudStack Spacing="2">

                            <MudStack Row AlignItems="AlignItems.Center" Class="device-card-topbar">
                                <MudImage Width="30" Src="/img/entra.png" ObjectFit="ObjectFit.ScaleDown" />
                                <MudText Typo="Typo.subtitle1">Entra ID - bruker</MudText>
                                <MudSpacer />
                            </MudStack>

                            <MudDivider Class="mb-5" />

                            @if (_state.EntraUser is null)
                            {
                                <MudText Typo="Typo.body2">
                                    Ingen Entra-data funnet.
                                </MudText>
                            }
                            else
                            {
                                <MudGrid Spacing="3">

                                    <MudItem xs="4">
                                        <MudText Typo="Typo.body2"><b>Bruker:</b></MudText>
                                    </MudItem>
                                    
                                    <MudItem xs="8">
                                        <MudText Typo="Typo.body2">
                                            @UiFormat.TextOrFallback(_state.EntraUser.DisplayName)
                                        </MudText>
                                    </MudItem>
                                    
                                    <MudItem xs="4">
                                        <MudText Typo="Typo.body2"><b>UPN:</b></MudText>
                                    </MudItem>
                                    
                                    <MudItem xs="8">
                                        <MudText Typo="Typo.body2">
                                            @UiFormat.TextOrFallback(_state.EntraUser.UserPrincipalName)
                                        </MudText>
                                    </MudItem>
                                    
                                    <MudItem xs="4">
                                        <MudText Typo="Typo.body2"><b>Tittel:</b></MudText>
                                    </MudItem>
                                    
                                    <MudItem xs="8">
                                        <MudText Typo="Typo.body2">
                                            @UiFormat.TextOrFallback(_state.EntraUser.JobTitle)
                                         </MudText>
                                    </MudItem>
                                    
                                    <MudItem xs="4">
                                        <MudText Typo="Typo.body2"><b>Antall enheter:</b></MudText>
                                    </MudItem>

                                    <MudItem xs="8">
                                        <ValueTextLink Text="@_state.UserDeviceCount?.ToString()"
                                                       IsLink="@(!string.IsNullOrEmpty(_state.EntraDeviceCount?.RawJson))"
                                                       OnClick="@(() => ShowJsonViewer(_state.EntraDeviceCount!.RawJson))" 
                                                       Typo="Typo.body2"/>
                                    </MudItem>
                                </MudGrid>
                            }

                        </MudStack>

                    </MudCardContent>

                    <MudCardActions Class="device-card-actions">
                        @if (!string.IsNullOrWhiteSpace(_state.EntraUser?.RawJson))
                        {
                            <MudButton Size="Size.Small"
                                       Variant="Variant.Text"
                                       Color="Color.Secondary"
                                       EndIcon="@Icons.Material.Outlined.Code"
                                       OnClick="@(async () => await ShowJsonViewer(_state.EntraUser.RawJson))">
                                Vis rådata
                            </MudButton>
                        }
                    </MudCardActions>

                </MudCard>
            </MudItem>

            @* ENTRA | Device *@
            <MudItem xs="12" md="6" lg="4">
                <MudCard Class="device-card" Elevation="3">

                    <MudCardContent Class="device-card-content">

                        <MudStack Spacing="2">

                            <MudStack Row AlignItems="AlignItems.Center" Class="device-card-topbar">
                                <MudImage Width="30" Src="/img/entra.png" ObjectFit="ObjectFit.ScaleDown" />
                                <MudText Typo="Typo.subtitle1">Entra ID - enhet</MudText>
                                <MudSpacer/>
                                @if(_state.EntraDevice is not null)
                                {
                                    <MudProgressCircular Indeterminate="@IsLoading(RefreshTarget.Entra)" Color="Color.Inherit" StrokeWidth="1">
                                        <ChildContent>
                                            <MudMenu Icon="@Icons.Material.Outlined.Settings" Class="pa-0" Dense=true AnchorOrigin="Origin.CenterLeft" TransformOrigin="Origin.CenterRight">
                                                <MudMenuItem Label="Oppdater" OnClick="@(() => RefreshAsync(RefreshTarget.Entra))" />
                                                <MudMenuItem Label="Aktiver" Disabled=true />
                                                <MudMenuItem Label="Deaktiver" Disabled=true />
                                                <MudMenuItem Label="Slett" OnClick="DeleteEntraDeviceAsync" Disabled="@(_state.AutopilotDevice is not null)" />
                                            </MudMenu>
                                        </ChildContent>
                                    </MudProgressCircular>
                                }
                            </MudStack>

                            <MudDivider Class="mb-5" />

                            @if (_state.EntraDevice is null)
                            {
                                <MudText Typo="Typo.body2">
                                    Ingen Entra-data funnet.
                                </MudText>
                            }
                            else
                            {
                                <MudGrid Spacing="3">
                                    <MudItem xs="4">
                                        <MudText Typo="Typo.body2"><b>Enhetsnavn:</b></MudText>
                                    </MudItem>
                                    <MudItem xs="8">
                                        <MudText Typo="Typo.body2">
                                            @UiFormat.TextOrFallback(_state.EntraDevice.DisplayName)
                                        </MudText>
                                    </MudItem>
                                    <MudItem xs="4">
                                        <MudText Typo="Typo.body2"><b>Profil:</b></MudText>
                                    </MudItem>
                                    <MudItem xs="8">
                                        <MudText Typo="Typo.body2">
                                            @UiFormat.TextOrFallback(_state.EntraDevice.EnrollmentProfileName)
                                         </MudText>
                                    </MudItem>
                                    <MudItem xs="4">
                                        <MudText Typo="Typo.body2"><b>Pålogget:</b></MudText>
                                    </MudItem>
                                    <MudItem xs="8">
                                        <MudText Typo="Typo.body2">
                                            @UiFormat.DateOrFallback(_state.EntraDevice.ApproximateLastSignInDateTime, fallback: "Ingen data")
                                        </MudText>
                                    </MudItem>
                                    <MudItem xs="4">
                                        <MudText Typo="Typo.body2"><b>Aktiv enhet:</b></MudText>
                                    </MudItem>
                                    <MudItem xs="8">
                                        <MudText Typo="Typo.body2">@UiFormat.YesNo(_state.EntraDevice.AccountEnabled)</MudText>
                                    </MudItem>
                                </MudGrid>
                            }

                        </MudStack>

                    </MudCardContent>

                    <MudCardActions Class="device-card-actions">
                        @if (!string.IsNullOrWhiteSpace(_state.EntraDevice?.RawJson))
                        {
                            <MudButton Size="Size.Small"
                                       Variant="Variant.Text"
                                       Color="Color.Secondary"
                                       EndIcon="@Icons.Material.Outlined.Code"
                                       OnClick="@(async () => await ShowJsonViewer(_state.EntraDevice.RawJson))">
                                Vis rådata
                            </MudButton>
                        }
                    </MudCardActions>

                </MudCard>
            </MudItem>

            @* INTUNE *@
            <MudItem xs="12" md="6" lg="4">
                <MudCard Class="device-card" Elevation="3">

                    <MudCardContent Class="device-card-content">

                        <MudStack Spacing="2">

                            <MudStack Row AlignItems="AlignItems.Center" Class="device-card-topbar">
                                <MudImage Width="30" Src="/img/intune.png" ObjectFit="ObjectFit.ScaleDown" />
                                <MudText Typo="Typo.subtitle1">Intune - enhet</MudText>
                                <MudSpacer />
                                @if(_state.ManagedDevice is not null)
                                {
                                    <MudProgressCircular Indeterminate="@IsLoading(RefreshTarget.Intune)" Color="Color.Inherit" StrokeWidth="1">
                                        <ChildContent>
                                            <MudMenu Icon="@Icons.Material.Outlined.Settings" Class="pa-0" Dense=true AnchorOrigin="Origin.CenterLeft" TransformOrigin="Origin.CenterRight">
                                                <MudMenuItem Label="Oppdater" OnClick="@(() => RefreshAsync(RefreshTarget.Intune))" />
                                                <MudMenuItem Label="Synkroniser" OnClick="SyncIntuneDeviceAsync" />
                                                <MudMenuItem Label="Fjernstyr" OnClick="RequestRemoteAssistanceAsync" Disabled="true" />
                                                <MudMenuItem Label="Wipe" OnClick="WipeIntuneDeviceAsync" />
                                                <MudMenuItem Label="Slett" onclick="DeleteIntuneDeviceAsync" />
                                            </MudMenu>
                                        </ChildContent>
                                    </MudProgressCircular>
                                }
                            </MudStack>
                            
                            <MudDivider Class="mb-5" />

                            <MudGrid Spacing="3">
                                <MudItem xs="4">
                                    <MudText Typo="Typo.body2"><b>Samsvarsstatus:</b></MudText>
                                </MudItem>
                                <MudItem xs="8">
                                    <MudText Typo="Typo.body2">@badge.label</MudText>
                                </MudItem>
                                <MudItem xs="4">
                                    <MudText Typo="Typo.body2"><b>OS versjon:</b></MudText>
                                </MudItem>
                                <MudItem xs="8">
                                    <MudText Typo="Typo.body2">
                                        @UiFormat.CombineOrFallback(_state.ManagedDevice.OperatingSystem, _state.ManagedDevice.OsVersion)
                                    </MudText>
                                </MudItem>
                                <MudItem xs="4">
                                    <MudText Typo="Typo.body2"><b>Siste sync:</b></MudText>
                                </MudItem>
                                <MudItem xs="8">
                                    <MudText Typo="Typo.body2">
                                        @UiFormat.DateOrFallback(_state.ManagedDevice.LastSyncDateTime, fallback: "ingen data")
                                    </MudText>
                                </MudItem>
                                <MudItem xs="4">
                                    <MudText Typo="Typo.body2"><b>WiFi MAC:</b></MudText>
                                </MudItem>
                                <MudItem xs="8">
                                    <MudText Typo="Typo.body2">
                                        @UiFormat.TextOrFallback(_state.ManagedDevice.WiFiMacAddress, fallback: "ukjent")
                                    </MudText>
                                </MudItem>
                            </MudGrid>

                        </MudStack>

                    </MudCardContent>

                    <MudCardActions Class="device-card-actions">
                        @if (!string.IsNullOrWhiteSpace(_state.ManagedDevice.RawJson))
                        {
                            <MudButton Size="Size.Small"
                                       Variant="Variant.Text"
                                       Color="Color.Secondary"
                                       EndIcon="@Icons.Material.Outlined.Code"
                                       OnClick="@(async () => await ShowJsonViewer(_state.ManagedDevice.RawJson))">
                                Vis rådata
                            </MudButton>
                        }
                    </MudCardActions>

                </MudCard>
            </MudItem>

            @* DEFENDER *@
            <MudItem xs="12" md="6" lg="4">
                <MudCard Class="device-card" Elevation="3">

                    <MudCardContent Class="device-card-content">

                        <MudStack Spacing="2">

                            <MudStack Row AlignItems="AlignItems.Center" Class="device-card-topbar">
                                <MudImage Width="30" Src="/img/defender.png" ObjectFit="ObjectFit.ScaleDown" />
                                <MudText Typo="Typo.subtitle1">Defender - enhet</MudText>
                                <MudSpacer />
                                @if (_state.DefenderDevice is not null)
                                {
                                    <MudProgressCircular Indeterminate="@IsLoading(RefreshTarget.Defender)" Color="Color.Inherit" StrokeWidth="1">
                                        <ChildContent>
                                            <MudMenu Icon="@Icons.Material.Outlined.Settings" Class="pa-0" Dense=true AnchorOrigin="Origin.CenterLeft" TransformOrigin="Origin.CenterRight">
                                                <MudMenuItem Label="Oppdater" OnClick="@(() => RefreshAsync(RefreshTarget.Defender))" />
                                                <MudMenuItem Label="Full skann" OnClick="@(async () => await RunDefenderScanAsync(DefenderScanType.Full))" />
                                                <MudMenuItem Label="Hurtigskann" OnClick="@(async () => await RunDefenderScanAsync(DefenderScanType.Quick))" />
                                            </MudMenu>
                                        </ChildContent>
                                    </MudProgressCircular>
                                }
                            </MudStack>

                            <MudDivider Class="mb-5" />

                            @if (_state.DefenderDevice is null)
                            {
                                <MudText Typo="Typo.body2">
                                    Ingen Defender-data funnet.
                                </MudText>
                            }
                            else
                            {
                                <MudGrid Spacing="3">
                                    <MudItem xs="4">
                                        <MudText Typo="Typo.body2"><b>Status:</b></MudText>
                                    </MudItem>
                                    <MudItem xs="8">
                                        <MudText Typo="Typo.body2">
                                            @UiFormat.TextOrFallback(_state.DefenderDevice.HealthStatus, fallback: "ukjent")
                                        </MudText>
                                    </MudItem>
                                    <MudItem xs="4">
                                        <MudText Typo="Typo.body2"><b>Eksponering:</b></MudText>
                                    </MudItem>
                                    <MudItem xs="8">
                                        <MudText Typo="Typo.body2">
                                            @UiFormat.TextOrFallback(_state.DefenderDevice.ExposureLevel, fallback: "ukjent")
                                        </MudText>
                                    </MudItem>
                                    <MudItem xs="4">
                                        <MudText Typo="Typo.body2"><b>Isolert:</b></MudText>
                                    </MudItem>
                                    <MudItem xs="8">
                                        <MudText Typo="Typo.body2">
                                            <MudText Typo="Typo.body2">@UiFormat.YesNo(_state.IsIsolated)</MudText>
                                        </MudText>
                                    </MudItem>
                                    <MudItem xs="4">
                                        <MudText Typo="Typo.body2"><b>Tagger:</b></MudText>
                                    </MudItem>
                                    <MudItem xs="8">
                                        <MudText Typo="Typo.body2">
                                            @UiFormat.JoinOrFallback(_state.DefenderDevice.MachineTags)
                                        </MudText>
                                    </MudItem>
                                </MudGrid>
                            }
                        
                        </MudStack>
                    
                    </MudCardContent>

                    <MudCardActions Class="device-card-actions">
                        @if (!string.IsNullOrWhiteSpace(_state.DefenderDevice?.RawJson))
                        {
                            <MudButton Size="Size.Small"
                                       Variant="Variant.Text"
